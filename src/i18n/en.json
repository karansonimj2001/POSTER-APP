  "helpCenter": {
    "headerTitle": "Help Center",
    "searchPlaceholder": "Search help topics...",
    "tabAccount": "Account",
    "tabDesigning": "Designing",
    "tabPayments": "Payments",
    "q1Question": "How do I add my own photo to a poster?",
    "q1Answer": "You can upload a personal photo in the Uploads tab after selecting a template. The photo will be automatically placed into the designated image slot.",
    "q2Question": "Can I use posters for commercial purposes?",
    "q2Answer": "Free templates are for personal use only. Pro members can use all templates for commercial purposes including client work and social media marketing.",
    "q3Question": "How do I cancel my Pro subscription?",
    "q3Answer": "Go to Settings > Subscription and tap Cancel. Your Pro benefits will continue until the end of the current billing period.",
    "q4Question": "My WhatsApp sharing isn't working.",
    "q4Answer": "Make sure WhatsApp is installed. If issues persist, try saving the poster to your gallery first, then share manually.",
    "q5Question": "How do I change font styles?",
    "q5Answer": "Tap the text element and select Font from the bottom toolbar. You can choose from 50+ fonts including Hindi scripts.",
    "q6Question": "How to use AI generation?",
    "q6Answer": "Tap the AI icon on the editor toolbar. Describe your idea and the AI will generate a custom design in seconds.",
    "q7Question": "Adjusting canvas dimensions manually.",
    "q7Answer": "Go to Settings > Canvas Size. You can choose from presets or enter custom dimensions in pixels.",
    "q8Question": "What is the refund policy?",
    "q8Answer": "We offer a 30-day money-back guarantee on all Pro subscriptions. Contact support to initiate the refund process.",
    "q9Question": "How to update billing info?",
    "q9Answer": "You can update your billing information in Settings > Subscription > Payment Methods."
  },
